# Vercel部署环境变量配置
# 在Vercel项目设置中配置以下环境变量

# JWT密钥（用于用户登录token签名，请修改为随机字符串）
JWT_SECRET=your-secure-jwt-secret-key-change-this-in-production

# 数据持久化存储（三选一即可，推荐使用Vercel KV）
# 方案1：Vercel KV（推荐，Vercel平台原生支持，免费额度足够使用）
# 在Vercel项目中添加KV Storage后会自动配置以下环境变量
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# 方案2：Upstash Redis（独立的Redis服务）
# 免费获取地址：https://upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 注意：如果不配置任何KV/Redis，用户数据将保存在Serverless函数内存中
# 由于Vercel Serverless函数是无状态的，函数重启后用户数据会重置
# 因此生产环境强烈建议配置KV存储
